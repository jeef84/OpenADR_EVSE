# Lab / site env for docker compose (copy to compose/.env and edit).
# compose/.env is gitignored. Do not commit real secrets.

VTN_PORT=3000
PG_PORT=5432
PG_USER=openadr
PG_DB=openadr
PG_PASSWORD=openadr
PG_TZ=America/Detroit
MQTT_PORT=1883

# Internal OAuth HMAC secret (base64, >=32 bytes decoded). Lab example only.
# Generate: openssl rand -base64 32
OAUTH_BASE64_SECRET=REPLACE_WITH_openssl_rand_base64_32
OAUTH_TOKEN_URL=http://vtn:3000/auth/token

BL_CLIENT_ID=bl-client
BL_CLIENT_SECRET=bl-client
VEN_CLIENT_ID=ven-client-client-id
VEN_CLIENT_SECRET=ven-client

# Must match the OpenEVSE WiFi gateway MQTT base topic.
OPENEVSE_MQTT_BASE=openevse
OPENEVSE_I_MIN=6
OPENEVSE_I_MAX=48
# claim (default, automation) | override (Manual path) | rapi (legacy)
OPENEVSE_CONTROL=claim
OPENEVSE_AUTO_RELEASE=true
# disabled (default): force stop. release/clear: yield to Auto/Eco (can stick at 6A).
OPENEVSE_STOP_MODE=disabled
# Mark gateway offline (and clear stale power) if no device MQTT for this long.
OPENEVSE_OFFLINE_SEC=60

ENGINE_INTERVAL_SEC=5
VEN_INTERVAL_SEC=3
VEN_SURPLUS_EMA_ALPHA=0.2
FIXTURE_SCENARIO=worked_stack
